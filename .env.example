# Copy this file to .env.local and paste your own keys.
# Never commit real secrets.

NODE_ENV=development
PORT=5050

# Frontend -> backend. Leave empty when Vite proxy/same-origin is used.
VITE_API_BASE_URL=

# Browser key for Google Maps JavaScript API.
# Restrict by HTTP referrers: http://localhost:5173/* and your production domain.
VITE_GOOGLE_MAPS_API_KEY=YOUR_BROWSER_MAPS_KEY
VITE_GOOGLE_MAPS_MAP_ID=YOUR_GOOGLE_MAP_ID

# Server key for Google Routes API. Keep this server-side only.
GOOGLE_MAPS_SERVER_KEY=YOUR_SERVER_ROUTES_KEY
GOOGLE_TRAFFIC_ESTIMATE_ENABLED=true
GOOGLE_TRAFFIC_REFRESH_CONCURRENCY=3

# Comma-separated production origins, e.g. https://granice.example.com,http://localhost:5173
CORS_ORIGINS=


# Production/pilot datastore. If empty, backend falls back to data/runtime-store.json.
DATABASE_URL=
DATABASE_SSL=false

# Required before real deployment. Used to sign session tokens.
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_HOURS=24

# Initial admin account. With PostgreSQL this is used only if borderflow_users is empty.
# With JSON fallback it is used only when data/runtime-store.json does not exist yet.
BORDERFLOW_ADMIN_NAME=Admin
BORDERFLOW_ADMIN_EMAIL=admin@borderflow.app
BORDERFLOW_ADMIN_PASSWORD=change-this-admin-password

# Optional seed for a regular user in JSON fallback/local demos.
BORDERFLOW_DEMO_USER_EMAIL=user@borderflow.app
BORDERFLOW_DEMO_USER_PASSWORD=change-this-user-password

# Camera ingest protection. Required for POST /api/camera-ingest.
CAMERA_INGEST_API_KEY=replace-with-a-long-random-ingest-key

# Optional server-side computer vision detector.
# Endpoint should accept { cameraId, cameraUrl, crossingId, direction, classes, timestamp }
# and return: { "counts": { "cars": 12, "vans": 3, "trucks": 2, "buses": 0 } }
# YOLO + ROI (V5 §6). OFF by default — only replaces the vehicle-detection step; wait still
# flows through evidence-cap + ROI gate + confidence calibration. Falls back to the heuristic
# if the model/runtime is unavailable (system never crashes). Endpoint must return per-vehicle
# detection boxes: { detections:[{type,x,y,w,h,confidence}], width, height }.
YOLO_ENABLED=false
# Shadow mode: run YOLO and record its result for comparison, but NEVER use it for the wait.
YOLO_SHADOW_MODE=false
YOLO_ENDPOINT=
YOLO_API_KEY=
YOLO_TIMEOUT_MS=6000
YOLO_MIN_CONFIDENCE=35
CAMERA_CV_ENDPOINT=
CAMERA_CV_API_KEY=

# Public source ingestion. Keep enabled for production pilot on Maljevac/Gradiška.
# Fetches BIHAMK border status text + AMS RS Gradiška page + calibrated camera snapshot signals.
SOURCE_FETCH_ENABLED=true
SOURCE_REFRESH_INTERVAL_MINUTES=10
SOURCE_FETCH_TIMEOUT_MS=4500

# Default false: history is filled only from real/source-derived snapshots.
# Set true only for a visual demo when you intentionally want modeled backfill.
HISTORY_ALLOW_MODEL_BACKFILL=false

# Built-in non-AI camera snapshot counter.
# It fetches direct JPEG camera images, analyzes calibrated ROI occupancy/edges,
# estimates visible vehicles/queue/throughput, stores snapshots in SQL, and feeds the wait formula.
CAMERA_SNAPSHOT_COUNTING_ENABLED=true
CAMERA_SNAPSHOT_TIMEOUT_MS=4500
CAMERA_SNAPSHOT_MIN_CONFIDENCE=46
CAMERA_SNAPSHOT_REFRESH_INTERVAL_MINUTES=5

# V4 intelligence layer
# How often a live prediction is sampled into the accuracy KPI store (predicted vs actual).
PREDICTION_SAMPLE_INTERVAL_MINUTES=10
# Camera signals older than this are treated as stale and dropped from the hard wait calc.
CAMERA_SIGNAL_MAX_AGE_MINUTES=45

# V5: measured-wait geofence (auto start/stop + GPS verification). Radii in metres.
GEOFENCE_APPROACH_RADIUS_M=1300
GEOFENCE_BORDER_RADIUS_M=350
GEOFENCE_EXIT_RADIUS_M=500
# V5: learned bias correction. OFF until enough measured data accumulates + operator opt-in.
BIAS_CORRECTION_ENABLED=false
BIAS_MIN_SAMPLE=8
BIAS_MAX_ADJUST_MIN=20

# Route guard prevents Google from showing a nearby snapped-pin/local-road loop for key crossings.
# Keep enabled for production; route is accepted only if it passes close to calibrated HR/checkpoint/BiH anchors.
ROUTE_GUARD_ENABLED=true
ROUTE_GUARD_PASS_METERS=500
ROUTE_GUARD_MAX_CROSSING_KM=8
