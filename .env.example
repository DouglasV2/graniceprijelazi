# Copy this file to .env.local and paste your own keys.
# Never commit real secrets.

NODE_ENV=development
PORT=5050

# Frontend -> backend. Leave empty when Vite proxy/same-origin is used.
VITE_API_BASE_URL=

# Browser key for Google Maps JavaScript API.
# Restrict by HTTP referrers: http://localhost:5173/* and your production domain.
VITE_GOOGLE_MAPS_API_KEY=YOUR_BROWSER_MAPS_KEY
VITE_GOOGLE_MAPS_MAP_ID=YOUR_GOOGLE_MAP_ID

# Server key for Google Routes API. Keep this server-side only.
GOOGLE_MAPS_SERVER_KEY=YOUR_SERVER_ROUTES_KEY
GOOGLE_TRAFFIC_ESTIMATE_ENABLED=true
GOOGLE_TRAFFIC_REFRESH_CONCURRENCY=3

# Comma-separated production origins, e.g. https://granice.example.com,http://localhost:5173
CORS_ORIGINS=


# Production/pilot datastore. If empty, backend falls back to data/runtime-store.json.
DATABASE_URL=
DATABASE_SSL=false

# Required before real deployment. Used to sign session tokens.
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_HOURS=24

# Initial admin account. With PostgreSQL this is used only if borderflow_users is empty.
# With JSON fallback it is used only when data/runtime-store.json does not exist yet.
BORDERFLOW_ADMIN_NAME=Admin
BORDERFLOW_ADMIN_EMAIL=admin@borderflow.app
BORDERFLOW_ADMIN_PASSWORD=change-this-admin-password

# Optional seed for a regular user in JSON fallback/local demos.
BORDERFLOW_DEMO_USER_EMAIL=user@borderflow.app
BORDERFLOW_DEMO_USER_PASSWORD=change-this-user-password

# Camera ingest protection. Required for POST /api/camera-ingest.
CAMERA_INGEST_API_KEY=replace-with-a-long-random-ingest-key

# Optional server-side computer vision detector.
# Endpoint should accept { cameraId, cameraUrl, crossingId, direction, classes, timestamp }
# and return: { "counts": { "cars": 12, "vans": 3, "trucks": 2, "buses": 0 } }
# ── YOLO / CV detector (cv-detector/ microservice) ──────────────────────────────────────────
# TURN-KEY: set CAMERA_CV_ENDPOINT to the running cv-detector and YOLO turns ON automatically
# (its detections replace the pixel heuristic for vehicle counts + the queue band; the band then
# feeds the wait via the camera-congestion override). Run the service from cv-detector/:
#   pip install -r cv-detector/requirements.txt
#   CV_AUTH_TOKEN=secret uvicorn app:app --host 0.0.0.0 --port 8000   (cd cv-detector)
# then set CAMERA_CV_ENDPOINT=http://<host>:8000/detect and CAMERA_CV_API_KEY=secret below.
# The service accepts the image as base64 (Node sends the bytes it already fetched) or imageUrl,
# and returns { counts, detections:[{type,x,y,w,h,confidence}], width, height }. On any failure it
# falls back to the heuristic (never crashes).
# YOLO_ENABLED: leave EMPTY for turn-key (on when an endpoint is set); =true/false to force.
YOLO_ENABLED=
# Shadow mode: run YOLO and record its result for comparison, but NEVER use it for the wait.
YOLO_SHADOW_ENABLED=false
# Controlled fusion: YOLO drives the wait ONLY when enabled AND the camera is allowlisted + eligible.
YOLO_FUSION_ENABLED=false
YOLO_SHADOW_CAMERA_ALLOWLIST=
YOLO_FUSION_CAMERA_ALLOWLIST=
YOLO_MAX_LATENCY_MS=8000
YOLO_REQUIRE_ROI=true
YOLO_REQUIRE_DIRECTION=true
YOLO_REQUIRE_COUNTLINE=true
YOLO_ENDPOINT=
YOLO_API_KEY=
YOLO_TIMEOUT_MS=6000
YOLO_MIN_CONFIDENCE=35
CAMERA_CV_ENDPOINT=
CAMERA_CV_API_KEY=

# Public source ingestion. Keep enabled for production pilot on Maljevac/Gradiška.
# Fetches BIHAMK border status text + AMS RS Gradiška page + calibrated camera snapshot signals.
SOURCE_FETCH_ENABLED=true
SOURCE_REFRESH_INTERVAL_MINUTES=10
SOURCE_FETCH_TIMEOUT_MS=4500

# Default false: history is filled only from real/source-derived snapshots.
# Set true only for a visual demo when you intentionally want modeled backfill.
HISTORY_ALLOW_MODEL_BACKFILL=false

# Built-in non-AI camera snapshot counter.
# It fetches direct JPEG camera images, analyzes calibrated ROI occupancy/edges,
# estimates visible vehicles/queue/throughput, stores snapshots in SQL, and feeds the wait formula.
CAMERA_SNAPSHOT_COUNTING_ENABLED=true
CAMERA_SNAPSHOT_TIMEOUT_MS=4500
CAMERA_SNAPSHOT_MIN_CONFIDENCE=46
CAMERA_SNAPSHOT_REFRESH_INTERVAL_MINUTES=5
# Bounded CV/camera concurrency (scaling safety as crossings/cameras grow). A full refresh runs at
# most CAMERA_REFRESH_CONCURRENCY (crossing,direction) jobs in parallel, and CAMERA_CV_CONCURRENCY
# caps how many YOLO inferences hit the cv-detector at once (never an inference storm / OOM).
CAMERA_REFRESH_CONCURRENCY=3
CAMERA_CV_CONCURRENCY=2
# Multi-frame stability (Pro): capture a few frames per refresh + use the MEDIAN in-queue count.
CAMERA_YOLO_MULTI_FRAME_ENABLED=true
CAMERA_YOLO_FRAME_COUNT=3
CAMERA_YOLO_FRAME_GAP_MS=2500
# Count→wait calibration: learns min/vehicle per crossing+direction once enough (count → measured
# wait) pairs exist; until then the heuristic is used. Lower minSamples to calibrate sooner.
CAMERA_CALIBRATION_MIN_SAMPLES=6
CAMERA_CALIBRATION_MAX_MAE=18
CAMERA_CALIBRATION_WINDOW_HOURS=1440
# NOTE: the cv-detector is a SEPARATE service — set these in ITS env, not here:
#   CV_MODEL=yolov8s.pt   (ladder: yolov8n=low-mem fallback, yolov8s=default, yolov8m=only with confirmed RAM)
#   CV_CONF=0.20          CV_MAX_CONCURRENCY=1          CV_IMGSZ=640   (cap inference resolution → less RAM)

# V4 intelligence layer
# How often a live prediction is sampled into the accuracy KPI store (predicted vs actual).
PREDICTION_SAMPLE_INTERVAL_MINUTES=10
# Camera signals older than this are treated as stale and dropped from the hard wait calc.
CAMERA_SIGNAL_MAX_AGE_MINUTES=45

# V5: measured-wait geofence (auto start/stop + GPS verification). Radii in metres.
GEOFENCE_APPROACH_RADIUS_M=1300
GEOFENCE_BORDER_RADIUS_M=350
GEOFENCE_EXIT_RADIUS_M=500
# V5: learned bias correction. OFF until enough measured data accumulates + operator opt-in.
BIAS_CORRECTION_ENABLED=false
BIAS_MIN_SAMPLE=8
BIAS_MAX_ADJUST_MIN=20

# ── Live "Moja lokacija" signal (anonymous A→B pass timing → verifiedLocation) ────────────────
# OFF by default: the map "Moja lokacija" button still shows the user's own location, but the
# anonymous pass signal only ARMS (server creates sessions + feeds the estimate) when this is true.
# Enable only once the start/end anchors for key crossings are validated. No raw GPS trail is ever
# stored — only the lifecycle status + the server-measured wait.
VERIFIED_LOCATION_ENABLED=false
# Optional per-crossing allow-list (comma-separated ids). Empty = all crossings when enabled above.
# Roll out to the flagship first: VERIFIED_LOCATION_CROSSINGS=maljevac arms A→B for Maljevac only;
# every other crossing returns armed:false/disarmed (working map, no session, no pings).
VERIFIED_LOCATION_CROSSINGS=
LOCATION_WAIT_MAX_ACCURACY_M=100
LOCATION_WAIT_PING_MIN_INTERVAL_SECONDS=20
LOCATION_WAIT_SESSION_MAX_MINUTES=240
LOCATION_WAIT_SIGNAL_MAX_AGE_MINUTES=45
# Salt for anonymising the per-session/user hash (defaults to SESSION_SECRET if empty).
LOCATION_WAIT_HASH_SALT=
LOCATION_WAIT_MIN_MOVE_METERS=25
LOCATION_WAIT_NEAR_ZONE_PING_SECONDS=15
LOCATION_WAIT_FAR_ZONE_PING_SECONDS=60
# Optional anchor radii (start/end geofences) — defaults are conservative.
LOCATION_WAIT_START_RADIUS_M=140
LOCATION_WAIT_END_RADIUS_M=160

# Route guard prevents Google from showing a nearby snapped-pin/local-road loop for key crossings.
# Keep enabled for production; route is accepted only if it passes close to calibrated HR/checkpoint/BiH anchors.
ROUTE_GUARD_ENABLED=true
ROUTE_GUARD_PASS_METERS=500
ROUTE_GUARD_MAX_CROSSING_KM=8

# ── Traffic + Vision prediction layer v2 (the differentiator) ────────────────────────────────
# OFF by default → v2 runs in SHADOW (computed + shown in the source breakdown / admin debug) but
# the headline wait still uses the proven legacy fusion. Set true to let v2 LEAD (border-segment
# Google delay + YOLO queue model + chat/verified ground truth; public only as fallback). Any v2
# failure falls back to the legacy estimate automatically.
PREDICTION_V2_ENABLED=false
GOOGLE_TRAFFIC_V2_ENABLED=true
YOLO_ROI_V2_ENABLED=true
TRAFFIC_VISION_DEBUG=false
# Multi-frame YOLO (stopped-vs-moving) — off by default (cost); single-frame otherwise.
CAMERA_YOLO_MULTI_FRAME_ENABLED=false
CAMERA_YOLO_FRAME_COUNT=3
CAMERA_YOLO_FRAME_GAP_MS=2500
# Hard cap on the whole multi-frame fetch+detect cycle; on timeout we fall back to single-frame.
CAMERA_YOLO_MULTI_FRAME_TIMEOUT_MS=12000

# ── ROI v2 (per-camera queue polygon) ────────────────────────────────────────────────────────
# Read committed STATIC_ROI_CONFIGS + runtime overrides so YOLO counts ONLY vehicles in the queue
# polygon (excludes parking / opposite direction / off-lane). On (default) is safe: a camera with
# no ROI config simply keeps the legacy count at lower confidence.
YOLO_ROI_CONFIG_ENABLED=true
# Internal polygon editor + camera debug UI at /internal/roi-editor and /api/internal/traffic-vision/*.
# OFF by default → those routes return 404 and are invisible to users. When on, the data endpoints
# still require an admin session OR a matching TRAFFIC_VISION_DEBUG_TOKEN.
YOLO_ROI_EDITOR_ENABLED=false
TRAFFIC_VISION_DEBUG_TOKEN=

# Public map display guardrails: keep the visible route as a clean border-control corridor, not a
# long city route with ugly off-road/cached anchor artifacts.
ROUTE_DISPLAY_MAX_METERS=2200
ROUTE_DISPLAY_MAX_WIGGLE_RATIO=2.4
ROUTE_HR_SIDE_EXTRA_METERS=0

# Traffic+Vision production release gate. /api/internal/traffic-vision/readiness must pass before
# turning PREDICTION_V2_ENABLED=true for the user-facing headline.
TRAFFIC_VISION_MIN_ROI_COVERAGE_PERCENT=70
TRAFFIC_VISION_MAX_FALLBACK_RATE=0.25
TRAFFIC_VISION_MIN_SNAPSHOTS_24H=100
TRAFFIC_VISION_MAX_MEDIAN_ERROR_MIN=7
TRAFFIC_VISION_MAX_P90_ERROR_MIN=15
